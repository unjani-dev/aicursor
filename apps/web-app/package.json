{
  "name": "web-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "node ../../node_modules/vite/bin/vite.js",
    "build": "tsc && node ../../node_modules/vite/bin/vite.js build",
    "build:win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.aicursor.desktop",
    "productName": "AI Cursor",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "main.cjs"
    ],
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@ai-cursor/core-vision": "file:../../packages/core-vision",
    "@ai-cursor/gesture-engine": "file:../../packages/gesture-engine",
    "@ai-cursor/input-mapper": "file:../../packages/input-mapper",
    "@mediapipe/tasks-vision": "^0.10.32"
  },
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "typescript": "^5.0.0",
    "vite": "^4.0.0"
  }
}